<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="invoice"
              pageWidth="595"
              pageHeight="842"
              columnWidth="515"
              leftMargin="40"
              rightMargin="40"
              topMargin="40"
              bottomMargin="40"
              whenNoDataType="AllSectionsNoDetail">

    <parameter name="PATIENT_NAME" class="java.lang.String"/>
    <parameter name="PATIENT_EMAIL" class="java.lang.String"/>
    <parameter name="PATIENT_ID" class="java.lang.String"/>
    <parameter name="TOTAL_BALANCE" class="java.math.BigDecimal"/>
    <parameter name="INVOICE_DATE" class="java.lang.String"/>

    <field name="treatmentName" class="java.lang.String"/>
    <field name="treatmentCategory" class="java.lang.String"/>
    <field name="price" class="java.math.BigDecimal"/>
    <field name="timestamp" class="java.time.LocalDateTime"/>

    <title>
        <band height="150">
            <!-- Header: clinic name left, INVOICE right -->
            <staticText>
                <reportElement x="0" y="0" width="260" height="32" forecolor="#141414"/>
                <textElement verticalAlignment="Middle">
                    <font size="18" isBold="true"/>
                </textElement>
                <text><![CDATA[Patient System]]></text>
            </staticText>
            <staticText>
                <reportElement x="260" y="0" width="255" height="32" forecolor="#141414"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="22" isBold="true"/>
                </textElement>
                <text><![CDATA[INVOICE]]></text>
            </staticText>
            <!-- Subline: tagline left, date right -->
            <staticText>
                <reportElement x="0" y="32" width="260" height="16" forecolor="#7A7A7A"/>
                <textElement verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <text><![CDATA[Medical Patient Management System]]></text>
            </staticText>
            <staticText>
                <reportElement x="380" y="32" width="50" height="16" forecolor="#7A7A7A"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <text><![CDATA[Date:]]></text>
            </staticText>
            <textField>
                <reportElement x="430" y="32" width="85" height="16" forecolor="#7A7A7A"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{INVOICE_DATE}]]></textFieldExpression>
            </textField>
            <!-- Divider -->
            <line>
                <reportElement x="0" y="58" width="515" height="1" forecolor="#C7C7C7"/>
            </line>
            <!-- Bill To section -->
            <staticText>
                <reportElement x="0" y="70" width="515" height="14" forecolor="#7A7A7A"/>
                <textElement verticalAlignment="Middle">
                    <font size="7" isBold="true"/>
                </textElement>
                <text><![CDATA[BILL TO]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="86" width="400" height="22" forecolor="#141414"/>
                <textElement verticalAlignment="Middle">
                    <font size="13" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{PATIENT_NAME}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="110" width="400" height="16" forecolor="#7A7A7A"/>
                <textElement verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{PATIENT_EMAIL}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="128" width="400" height="16" forecolor="#7A7A7A"/>
                <textElement verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA["Patient ID: " + $P{PATIENT_ID}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="28">
            <rectangle>
                <reportElement x="0" y="0" width="515" height="28" backcolor="#141414"/>
                <graphicElement>
                    <pen lineWidth="0.0"/>
                </graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="8" y="0" width="162" height="28" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <text><![CDATA[Treatment]]></text>
            </staticText>
            <staticText>
                <reportElement x="170" y="0" width="120" height="28" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <text><![CDATA[Category]]></text>
            </staticText>
            <staticText>
                <reportElement x="290" y="0" width="110" height="28" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <text><![CDATA[Date]]></text>
            </staticText>
            <staticText>
                <reportElement x="400" y="0" width="115" height="28" forecolor="#FFFFFF"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <text><![CDATA[Amount]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="24">
            <textField isStretchWithOverflow="true">
                <reportElement x="8" y="0" width="162" height="24" forecolor="#141414"/>
                <textElement verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{treatmentName}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="170" y="0" width="120" height="24" forecolor="#7A7A7A"/>
                <textElement verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{treatmentCategory}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="290" y="0" width="110" height="24" forecolor="#7A7A7A"/>
                <textElement verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{timestamp} != null ? $F{timestamp}.format(java.time.format.DateTimeFormatter.ofPattern("MMM dd, yyyy")) : ""]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="400" y="0" width="115" height="24" forecolor="#141414"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[String.format("$%,.2f", $F{price})]]></textFieldExpression>
            </textField>
            <line>
                <reportElement x="0" y="23" width="515" height="1" forecolor="#EEEEEE"/>
            </line>
        </band>
    </detail>

    <summary>
        <band height="60">
            <line>
                <reportElement x="0" y="8" width="515" height="1" forecolor="#141414"/>
            </line>
            <staticText>
                <reportElement x="0" y="18" width="400" height="28" forecolor="#141414"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="11" isBold="true"/>
                </textElement>
                <text><![CDATA[Total Balance:]]></text>
            </staticText>
            <textField>
                <reportElement x="400" y="18" width="115" height="28" forecolor="#141414"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="11" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[String.format("$%,.2f", $P{TOTAL_BALANCE})]]></textFieldExpression>
            </textField>
        </band>
    </summary>

</jasperReport>
